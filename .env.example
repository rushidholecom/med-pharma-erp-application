# Compose project metadata
COMPOSE_PROJECT_NAME=pharma-erp-platform

# Set to local-db for a bundled MongoDB container.
# Clear this value and update MONGODB_URI if you want to use MongoDB Atlas or any external MongoDB server.
COMPOSE_PROFILES=local-db

# Host ports
FRONTEND_HOST_PORT=3000
AUTH_SERVICE_HOST_PORT=8081
EMPLOYEE_SERVICE_HOST_PORT=8082
MEDICINE_CATALOG_SERVICE_HOST_PORT=8083
INVENTORY_SERVICE_HOST_PORT=8084
PROCUREMENT_SERVICE_HOST_PORT=8085
SALES_DISTRIBUTION_SERVICE_HOST_PORT=8086
PRODUCTION_BATCH_SERVICE_HOST_PORT=8087
QUALITY_CONTROL_SERVICE_HOST_PORT=8088
WAREHOUSE_LOGISTICS_SERVICE_HOST_PORT=8089
FINANCE_BILLING_SERVICE_HOST_PORT=8090
MONGO_HOST_PORT=27017

# Shared backend runtime
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
JAVA_OPTS=-Xms128m -Xmx384m
JWT_SECRET=change-this-before-production-use

# Local Docker MongoDB credentials
MONGO_ROOT_USERNAME=rushi
MONGO_ROOT_PASSWORD=redhat123

# Shared MongoDB connection used by all services
# Local Docker example:
MONGODB_URI=mongodb+srv://rushi:redhat123@cluster0.hsftcq8.mongodb.net/?appName=Cluster0

# Per-service database names
AUTH_MONGODB_DATABASE=pharma_auth_db
EMPLOYEE_MONGODB_DATABASE=pharma_employee_db
CATALOG_MONGODB_DATABASE=pharma_catalog_db
INVENTORY_MONGODB_DATABASE=pharma_inventory_db
PROCUREMENT_MONGODB_DATABASE=pharma_procurement_db
SALES_MONGODB_DATABASE=pharma_sales_db
PRODUCTION_MONGODB_DATABASE=pharma_production_db
QUALITY_MONGODB_DATABASE=pharma_quality_db
WAREHOUSE_MONGODB_DATABASE=pharma_warehouse_db
FINANCE_MONGODB_DATABASE=pharma_finance_db

# Optional per-service MongoDB URI overrides
# Uncomment only if a service must connect to a different MongoDB cluster.
# AUTH_MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority&appName=PharmaERP
# EMPLOYEE_MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority&appName=PharmaERP
# CATALOG_MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority&appName=PharmaERP
# INVENTORY_MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority&appName=PharmaERP
# PROCUREMENT_MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority&appName=PharmaERP
# SALES_MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority&appName=PharmaERP
# PRODUCTION_MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority&appName=PharmaERP
# QUALITY_MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority&appName=PharmaERP
# WAREHOUSE_MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority&appName=PharmaERP
# FINANCE_MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority&appName=PharmaERP

# Frontend API targets used during the Vite build
VITE_AUTH_SERVICE_URL=/proxy/auth-service
VITE_EMPLOYEE_SERVICE_URL=/proxy/employee-service
VITE_CATALOG_SERVICE_URL=/proxy/medicine-catalog-service
VITE_INVENTORY_SERVICE_URL=/proxy/inventory-service
VITE_PROCUREMENT_SERVICE_URL=/proxy/procurement-service
VITE_SALES_SERVICE_URL=/proxy/sales-distribution-service
VITE_PRODUCTION_SERVICE_URL=/proxy/production-batch-service
VITE_QUALITY_SERVICE_URL=/proxy/quality-control-service
VITE_WAREHOUSE_SERVICE_URL=/proxy/warehouse-logistics-service
VITE_FINANCE_SERVICE_URL=/proxy/finance-billing-service
